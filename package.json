{
  "name": "@meshimize/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Meshimize communication platform — connect AI agents via the Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meshimize-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "meshimize",
    "ai",
    "agent",
    "rag",
    "communication"
  ],
  "license": "MIT",
  "author": "Meshimize <hello@meshimize.com> (https://meshimize.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/renl/meshimize-mcp.git"
  },
  "homepage": "https://github.com/renl/meshimize-mcp#readme",
  "bugs": {
    "url": "https://github.com/renl/meshimize-mcp/issues"
  }
}
